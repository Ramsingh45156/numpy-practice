   "source": [
    "# Broadcasting kya hota hai?\n",
    "\n",
    "Jab different size ke arrays par operation hota hai\n",
    "NumPy khud chhote array ko bada bana deta hai (virtually)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "4d6f1936-2e04-4e61-9675-fca4fedd576a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[3 4 5]\n"
     ]
    }
   ],
   "source": [
    "import numpy as np\n",
    "\n",
    "a = np.array([1,2,3])\n",
    "b = 2\n",
    "\n",
    "print(a + b)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "98466958-5854-4af4-91d7-417b86d23b4c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[1 2 3 4]\n",
      "Array shape:- (4,)\n"
     ]
    }
   ],
   "source": [
    "arr1 = np.array([1,2,3,4])\n",
    "print(arr1)\n",
    "print(\"Array shape:-\",arr1.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "8245ae97-f247-40d0-b129-3aa5e5f0b83c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[[1]\n",
      " [2]\n",
      " [3]]\n",
      "Array shape:- (3, 1)\n"
     ]
    }
   ],
   "source": [
    "arr2 = np.array([[1],[2],[3]])\n",
    "print(arr2)\n",
    "print(\"Array shape:-\",arr2.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "71f91bdb-307a-421a-b675-33c1e8c5b7a9",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[[2 3 4 5]\n",
      " [3 4 5 6]\n",
      " [4 5 6 7]]\n"
     ]
    }
   ],
   "source": [
    "print(arr1+arr2)"
   ]
  },
  {
   "cell_type": "raw",
   "id": "31c2af95-c911-4929-8e22-659149d43268",
   "metadata": {},
   "source": [
    "[[1+1  2+1  3+1  4+1]   → [2 3 4 5]\n",
    " [1+2  2+2  3+2  4+2]   → [3 4 5 6]\n",
    " [1+3  2+3  3+3  4+3]]  → [4 5 6 7]"
   ]
  },
